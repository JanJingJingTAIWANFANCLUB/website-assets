<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>Jan & JingJing Official Website | TAIWAN FC</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    
    <style>
        :root { 
            --bg-color: #f2efe9; 
            --text-color: #2c2c2c;
            --accent-color: #8e7f71;
            --serif: 'Playfair Display', serif;
            --sans: 'Inter', "Noto Sans TC", sans-serif;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        html, body { 
            margin: 0; padding: 0; width: 100%; height: 100%;
            background: var(--bg-color); color: var(--text-color); font-family: var(--sans);
        }

        body.locked { overflow: hidden; position: fixed; }
        body.unlocked { overflow-x: hidden; overflow-y: auto; }

        /* --- 進場畫面 --- */
        #splash-screen { 
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: 9999; display: flex; flex-direction: column; 
            justify-content: flex-end; align-items: center; 
            transition: opacity 0.8s ease; padding-bottom: 15vh; 
            background: #000; overscroll-behavior: none; 
        }
        #bg-video { 
            position: absolute; top: 50%; left: 50%; min-width: 100%; min-height: 100%; 
            transform: translate(-50%, -50%); z-index: -1; object-fit: cover; opacity: 0.8;
        }
        .enter-btn { 
            position: relative; z-index: 10000; background: rgba(255,255,255,0.9); 
            border: none; padding: 18px 50px; border-radius: 50px; font-weight: 600; 
            cursor: pointer; letter-spacing: 2px; box-shadow: 0 10px 30px rgba(0,0,0,0.3); 
            backdrop-filter: blur(5px); font-size: 1rem; color: #333; text-transform: uppercase;
        }

        /* --- 頂部導覽 --- */
        .nav-bar { 
            position: fixed; top: 0; width: 100%; 
            display: flex; justify-content: space-between; align-items: center; 
            padding: 20px 5%; z-index: 1000; 
            background: rgba(242, 239, 233, 0.95); backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }
        .nav-links { display: flex; gap: 20px; }
        .nav-links a { text-decoration: none; color: var(--text-color); font-size: 11px; letter-spacing: 1px; font-weight: 600; text-transform: uppercase; }

        /* --- 修正：音樂控制按鈕移至右下角防止重疊 --- */
        .music-control {
            position: fixed; 
            bottom: 30px; /* 改為底部 */
            right: 25px; 
            z-index: 2000; /* 確保在最上層 */
            cursor: pointer; 
            width: 45px; height: 45px;
            display: none; align-items: center; justify-content: center;
            background: white;
            color: var(--text-color);
            border-radius: 50%; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.15);
            transition: all 0.3s ease;
        }
        .music-control i { font-size: 18px; }

        /* --- 跑馬燈 --- */
        .ticker-wrap { 
            width: 100%; overflow: hidden; background: #fff; 
            border-top: 1px solid #eee; border-bottom: 1px solid #eee; 
            padding: 12px 0; margin-top: 80px; 
        }
        .ticker { display: flex; white-space: nowrap; animation: ticker 45s linear infinite; width: fit-content; }
        .ticker span { font-family: var(--serif); font-size: 13px; letter-spacing: 6px; padding: 0 60px; font-style: italic; text-transform: uppercase; }
        @keyframes ticker { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

        /* --- 主要內容區 --- */
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        .section-title { font-family: var(--serif); font-size: 2.5rem; font-style: italic; text-align: center; margin: 60px 0 40px; letter-spacing: 2px; }

        /* --- 藝人 Profiles --- */
        .immersive-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-bottom: 80px; }
        .artist-card { text-align: left; }
        .janhae-dual-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px; }
        .image-container { width: 100%; border-radius: 4px; overflow: hidden; background: #fff; padding: 8px; box-shadow: 0 5px 15px rgba(0,0,0,0.03); }
        .image-container img { width: 100%; height: auto; display: block; }
        .artist-name { font-family: var(--serif); font-size: 1.6rem; margin: 15px 0 5px; font-style: italic; }
        .artist-sub { color: var(--accent-color); font-size: 10px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 15px; border-bottom: 1px solid #ddd; padding-bottom: 10px;}
        
        .profile-table { width: 100%; border-collapse: collapse; margin-bottom: 25px; }
        .profile-table tr { border-bottom: 1px solid #e0ddd7; }
        .profile-table td { padding: 12px 0; font-size: 12px; }
        .label { font-weight: 600; text-transform: uppercase; color: var(--accent-color); width: 100px; font-size: 11px; }

        .card-social { display: flex; gap: 20px; margin-top: 20px; border-top: 1px solid #ddd; padding-top: 20px; }
        .card-social a { color: var(--text-color); font-size: 1.3rem; transition: all 0.3s ease; opacity: 0.6; }
        .card-social a:hover { opacity: 1; color: var(--accent-color); transform: translateY(-3px); }

        /* --- Videos --- */
        .category-label { font-family: var(--serif); font-size: 1.2rem; font-style: italic; color: var(--accent-color); margin: 50px 0 20px; display: block; border-left: 3px solid var(--accent-color); padding-left: 15px; }
        .work-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 40px; margin-bottom: 60px; }
        .video-container { width: 100%; aspect-ratio: 16/9; background: #000; border-radius: 4px; overflow: hidden; }
        .video-container iframe { width: 100%; height: 100%; border: none; }

        footer { margin-top: 100px; padding: 60px 0; border-top: 1px solid #ddd; text-align: center; }
        .footer-text { font-family: var(--serif); font-size: 12px; letter-spacing: 2px; color: var(--accent-color); text-transform: uppercase; }

        @media (max-width: 1024px) {
            .immersive-grid, .janhae-dual-cards { grid-template-columns: 1fr; }
            .work-grid { grid-template-columns: 1fr; }
            .music-control { bottom: 20px; right: 20px; } /* 手機版略微調整位置 */
        }
    </style>
</head>
